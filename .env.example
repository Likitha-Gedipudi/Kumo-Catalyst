# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# SECURITY WARNING: Never use NEXT_PUBLIC_* prefix for API keys!
# NEXT_PUBLIC variables are exposed to the browser.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The public URL where this app is hosted (e.g. Cloud Run). Used for self-referential links and server-side absolute URLs.
# AI Studio may inject this at runtime.
APP_URL="MY_APP_URL"

# KUMO_API_KEY: Required for the Python sidecar. Never commit real keys.
KUMO_API_KEY="your_kumo_api_key_here"

# KUMO_REST_API_KEY: Optional. REST API key (format customer_id:secret) for /api/kumo/jobs — server-side only.
# See https://kumo.ai/docs/rest-api/
# KUMO_REST_API_KEY="your_customer_id:your_secret"

# KUMO_REST_BASE_URL: Optional. Default https://api.kumo.ai
# KUMO_REST_BASE_URL="https://api.kumo.ai"

# KUMO_APP_BASE_URL: Optional. Link to your Kumo Cloud / console UI (shown on Board when set).
# KUMO_APP_BASE_URL="https://app.kumo.ai"

# SIDECAR_CORS_ORIGINS: Comma-separated browser origins allowed to call the sidecar API.
# Default (if unset): http://localhost:3000,http://127.0.0.1:3000
# Production: set to your deployed Next.js origin(s), e.g. https://app.example.com
# Use * only for demos (allows any origin).
# SIDECAR_CORS_ORIGINS="https://your-app.example.com"

# KUMO_API_URL: Optional. The Kumo REST API endpoint (defaults to https://api.kumo.ai/v1/predict)
KUMO_API_URL="https://api.kumo.ai/v1/predict"

# KUMO_SIDECAR_URL: Optional. URL for the local Python sidecar running the Kumo SDK.
KUMO_SIDECAR_URL="http://localhost:8000"
